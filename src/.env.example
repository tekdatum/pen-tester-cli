# Pentester CLI — Environment Configuration Template
# Copy to .env and customize. For personal overrides, use .env.local (git-ignored).
#
# All settings use the PENTESTER_ prefix; nested settings use a "__" delimiter.
# List-valued settings must be JSON arrays, e.g. ["a","b"] (GENERATOR_KEYS and the
# --auditors CLI flag accept comma-separated values instead).
# The provider API keys below are loaded from this file into the environment at startup.

# --- Core ---
# Target category: SEMANTIC_FENCE | LLM
PENTESTER_TARGET_TYPE=SEMANTIC_FENCE
# Auditors to run (JSON array of garak, pyrit, inspect_ai, promptfoo). Empty = all.
# PENTESTER_AUDITORS=["promptfoo"]
# Global attack cap; per-auditor caps (e.g. PENTESTER_GARAK__MAX_ATTACKS) override it.
# PENTESTER_MAX_ATTACKS=50

# --- Reporting ---
# Report output dir. Also the base for promptfoo working files (<dir>/promptfoo/).
PENTESTER_REPORTING__OUTPUT_DIR_PATH=./output/
# Report formats (comma-separated): html, pdf, csv, markdown
# PENTESTER_REPORTING__GENERATOR_KEYS=html,pdf,csv,markdown

# --- Target: SEMANTIC_FENCE via a custom handler ---
# (For HTTP curl targets, pass --curl-command on the CLI to avoid $PROMPT interpolation in .env.)
# PENTESTER_SCANNER__CUSTOM_HANDLER=my_handler.py:MyServiceHandler
# PENTESTER_SCANNER__JSON_DOT_TARGET=body.valid
# PENTESTER_SCANNER__RESPONSE_TEXT_TARGET=body.choices.0.message.content

# --- LLM: the target when TARGET_TYPE=LLM, and the judge/scorer for other auditors ---
# Provider: openai | anthropic | gemini | deepseek
# PENTESTER_LLM__PROVIDER=openai
# PENTESTER_LLM__MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=...

# --- Promptfoo (optional) ---
# Attack-generation and judge models (full provider:model strings):
# PENTESTER_PROMPTFOO__ATTACK_GENERATION_MODEL=deepseek:<deepseek model>
# PENTESTER_PROMPTFOO__JUDGE_MODEL=deepseek:<deepseek model>
# Working dir override; defaults to <PENTESTER_REPORTING__OUTPUT_DIR_PATH>/promptfoo:
# PENTESTER_PROMPTFOO__OUTPUT_PATH=./output/promptfoo
